const CLK_FREQ: u32 = 33000000;

func WriteCharacter(character: i8) {
    while (*(0xFFFC as *const u32) & 2) != 0 {}
    *(0xFFFF as *mut i8) = character;
}

func Write(mut string: *const i8) {
    while *string != '\0' {
        WriteCharacter(*string);
        string += 1;
    }
}

func WriteLine(string: *const i8) {
    Write(string);
    WriteCharacter('\n');
}

func WriteInteger(mut value: i32) {
    if value < 0 {
        WriteCharacter('-');
        value = -value;
    }

    if value >= 10 {
        WriteInteger(value / 10);
    }

    WriteCharacter(48 + (value % 10) as i8);
}

func WriteInteger(value: u32) {
    if value >= 10 {
        WriteInteger(value / 10);
    }

    WriteCharacter(48 + (value % 10) as i8);
}

func WriteHexadecimal(value: u32) {
    Write("0x");
    let mut i: u32 = 7;

    loop {
        let nibble = ((value >> (i * 4)) & 0xF) as u8;

        if nibble < 10 {
            WriteCharacter('0' + nibble as i8);
        } else {
            WriteCharacter('A' + (nibble as i8 - 10));
        }

        if i == 0 {
            break;
        } i = i - 1;
    }
}

func SetLEDs(leds: i8) {
    *(0xFFF0 as *mut i8) = leds;
}

func SetWS2812(_r: u8, _g: u8, _b: u8, brightness: u8) {
    let (mut r, mut g, mut b) = (_r as u32, _g as u32, _b as u32);

    if brightness < 255u8 {
        r = (r * brightness as u32) / 255;
        g = (g * brightness as u32) / 255;
        b = (b * brightness as u32) / 255;
    }

    *(0xFFE0 as *mut u32) = (g << 16) | (r << 8) | b;
}

func HasCharacter() -> bool {
    ret (*(0xFFFC as *const u32) & 1) != 0;
}

func ReadCharacter() -> i8 {
    ret *(0xFFFF as *const u32) as i8;
}

func ButtonPressed() -> bool {
    ret (*(0xFFF4 as *const u32) & 1) == 0;
}

func GetTime() -> u32 {
    ret *(0xFFEC as *const u32);
}

func Sleep(ms: u32) {
    let start = GetTime();
    while GetTime() - start < ms {}
}

func SetBaudRate(baud: u32) {
    *(0xFFF8 as *mut u32) = CLK_FREQ / baud;
}

