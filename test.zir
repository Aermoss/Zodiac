    pub quotient: u32,
    pub remainder: u32;
}

func SoftwareDivide(dividend: u32, divisor: u32) -> DivisionResult {
    let result = DivisionResult();
    result.remainder = dividend;

    while result.remainder >= divisor {
        result.remainder -= divisor;
        result.quotient += 1u32;
    } ret result;
} */

@nomangle
func Main() {
    SetBaudRate(115200u32);
    Sleep(1u32);

    /* let software_start = GetTime();
    let software_result = SoftwareDivide(CLK_FREQ, 115200u32);
    let software_time = GetTime() - software_start;

    Write("Software division took ");
    WriteInteger(software_start);
    WriteLine(" ms.");

    let hardware_start = GetTime();
    let hardware_result = CLK_FREQ / 115200u32;
    let hardware_time = GetTime() - hardware_start;

    Write("Hardware division took ");
    WriteInteger(hardware_time);
    WriteLine(" ms."); */

    WriteLine("Zodiac interactive terminal initialized!");
    WriteLine("Type anything to echo, press 1-6 to toggle LEDs, or +/- to change RGB brightness.");
    WriteLine("Press the button on the board to cycle WS2812 animation modes.");

    let address = 0x40000000u32 as *mut u32;
    WriteLine("Running SDRAM test...");
    *address = 0xDEADBEEFu32;
    WriteLine("Written 0xDEADBEEF to 0x40000000.");
    let value = *address;
    Write("Read ");
    WriteHexadecimal(value);
    WriteLine(" from 0x40000000.");

    if value == 0xDEADBEEFu32 {
        WriteLine("SDRAM test successful!");
    } else {
        WriteLine("SDRAM test failed!");
    }

    let mut color_state = 0i32;
    let (mut r, mut g, mut b) = (255u8, 0u8, 0u8);
    let mut led_state = 0x3Fi8;
    SetLEDs(led_state);

    let mut mode = 0u32;
    let mut key_state = !ButtonPressed();
    let mut next_tick = GetTime() + 10u32;
    let mut brightness = 64u8;

    loop {
        let now = GetTime();

        if ButtonPressed() {
            if key_state {
                mode += 1u32;
                if mode > 4u32 { mode = 0u32; }
                key_state = false;
                Write("WS2812 Mode: ");
                WriteInteger(mode);
                Write("\n");
            }
        } else {
            key_state = true;
        }

        if now >= next_tick {
            next_tick = now + 10u32;

            if mode == 0u32 {
                if color_state == 0i32 {
                    g = g + 5u8;
                    if g >= 255u8 { g = 255u8; color_state = 1i32; }
                } else if color_state == 1i32 {
                    if r <= 5u8 { r = 0u8; color_state = 2i32; } else { r = r - 5u8; }
                } else if color_state == 2i32 {
                    b = b + 5u8;
                    if b >= 255u8 { b = 255u8; color_state = 3i32; }
                } else if color_state == 3i32 {
                    if g <= 5u8 { g = 0u8; color_state = 4i32; } else { g = g - 5u8; }
                } else if color_state == 4i32 {
                    r = r + 5u8;
                    if r >= 255u8 { r = 255u8; color_state = 5i32; }
                } else {
                    if b <= 5u8 { b = 0u8; color_state = 0i32; } else { b = b - 5u8; }
                }

                SetWS2812(r, g, b, brightness);
            } else if mode == 1u32 {
                SetWS2812(255u8, 0u8, 0u8, brightness);
            } else if mode == 2u32 {
                SetWS2812(0u8, 255u8, 0u8, brightness);
            } else if mode == 3u32 {
                SetWS2812(0u8, 0u8, 255u8, brightness);
            } else {
                SetWS2812(0u8, 0u8, 0u8, brightness);
            }
        }

        if HasCharacter() {
            let c = ReadCharacter();

            if c >= '1' && c <= '6' {
                led_state ^= 1i8 << (c - '1');
                SetLEDs(led_state);
            } else if c == '+' {
                if brightness >= 247u8 { brightness = 255u8; }
                else { brightness += 8u8; }
                Write("Brightness: ");
                WriteInteger(brightness as u32);
                Write("/255\n");
            } else if c == '-' {
                if brightness <= 8u8 { brightness = 0u8; }
                else { brightness -= 8u8; }
                Write("Brightness: ");
                WriteInteger(brightness as u32);
                Write("/255\n");
            } else {
                WriteCharacter(c);
            }
        }
    }
}
