    pub quotient: u32,
    pub remainder: u32;
}

func SoftwareDivide(dividend: u32, divisor: u32) -> DivisionResult {
    let result = DivisionResult();
    result.remainder = dividend;

    while result.remainder >= divisor {
        result.remainder -= divisor;
        result.quotient += 1;
    } ret result;
} */

@nomangle
func Main() {
    SetBaudRate(115200);
    Sleep(1);

    /* let software_start = GetTime();
    let software_result = SoftwareDivide(CLK_FREQ, 115200);
    let software_time = GetTime() - software_start;

    Write("Software division took ");
    WriteInteger(software_start);
    WriteLine(" ms.");

    let hardware_start = GetTime();
    let hardware_result = CLK_FREQ / 115200;
    let hardware_time = GetTime() - hardware_start;

    Write("Hardware division took ");
    WriteInteger(hardware_time);
    WriteLine(" ms."); */

    WriteLine("Zodiac interactive terminal initialized!");
    WriteLine("Type anything to echo, press 1-6 to toggle LEDs, or +/- to change RGB brightness.");
    WriteLine("Press the button on the board to cycle WS2812 animation modes.");

    let address = 0x40000000u32 as *mut u32;
    WriteLine("Running SDRAM test...");
    *address = 0xDEADBEEFu32;
    WriteLine("Written 0xDEADBEEF to 0x40000000.");
    let value = *address;
    Write("Read ");
    WriteHexadecimal(value);
    WriteLine(" from 0x40000000.");

    if value == 0xDEADBEEFu32 {
        WriteLine("SDRAM test successful!");
    } else {
        WriteLine("SDRAM test failed!");
    }

    let mut color_state = 0;
    let (mut r: u8, mut g: u8, mut b: u8) = (255u8, 0, 0);
    let mut led_state: i8 = 0x3F;
    SetLEDs(led_state);

    let mut mode = 0;
    let mut key_state = !ButtonPressed();
    let mut next_tick = GetTime() + 10;
    let mut brightness: u8 = 64;

    loop {
        let now = GetTime();

        if ButtonPressed() {
            if key_state {
                mode += 1;
                if mode > 4 { mode = 0; }
                key_state = false;
                Write("WS2812 Mode: ");
                WriteInteger(mode);
                Write("\n");
            }
        } else {
            key_state = true;
        }

        if now >= next_tick {
            next_tick = now + 10;

            if mode == 0 {
                if color_state == 0 {
                    g = g + 5;
                    if g >= 255u8 { g = 255u8; color_state = 1; }
                } else if color_state == 1 {
                    if r <= 5 { r = 0; color_state = 2; } else { r = r - 5; }
                } else if color_state == 2 {
                    b = b + 5;
                    if b >= 255u8 { b = 255u8; color_state = 3; }
                } else if color_state == 3 {
                    if g <= 5 { g = 0; color_state = 4; } else { g = g - 5; }
                } else if color_state == 4 {
                    r = r + 5;
                    if r >= 255u8 { r = 255u8; color_state = 5; }
                } else {
                    if b <= 5 { b = 0; color_state = 0; } else { b = b - 5; }
                }

                SetWS2812(r, g, b, brightness);
            } else if mode == 1 {
                SetWS2812(255u8, 0, 0, brightness);
            } else if mode == 2 {
                SetWS2812(0, 255u8, 0, brightness);
            } else if mode == 3 {
                SetWS2812(0, 0, 255u8, brightness);
            } else {
                SetWS2812(0, 0, 0, brightness);
            }
        }

        if HasCharacter() {
            let c = ReadCharacter();

            if c >= '1' && c <= '6' {
                led_state ^= 1 << (c - '1');
                SetLEDs(led_state);
            } else if c == '+' {
                if brightness >= 247u8 { brightness = 255u8; }
                else { brightness += 8; }
                Write("Brightness: ");
                WriteInteger(brightness as u32);
                Write("/255\n");
            } else if c == '-' {
                if brightness <= 8 { brightness = 0; }
                else { brightness = brightness - 8; }
                Write("Brightness: ");
                WriteInteger(brightness as u32);
                Write("/255\n");
            } else {
                WriteCharacter(c);
            }
        }
    }
}
