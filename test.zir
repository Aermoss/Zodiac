const CLK_FREQ: u32 = 33000000;

fn WriteCharacter(character: i8) {
    while (*(0xFFFC as *u32) & 2) != 0 {}
    *(0xFFFF as *mut i8) = character;
}

fn Write(mut string: *i8) {
    while *string != '\0' {
        WriteCharacter(*string);
        string += 1;
    }
}

fn WriteLine(string: *i8) {
    Write(string);
    WriteCharacter('\n');
}

fn WriteInteger(mut value: i32) {
    if value < 0 {
        WriteCharacter('-');
        value = -value;
    }

    if value >= 10 {
        WriteInteger(value / 10);
    }

    WriteCharacter(48 + (value % 10) as i8);
}

fn WriteInteger(value: u32) {
    if value >= 10 {
        WriteInteger(value / 10);
    }

    WriteCharacter(48 + (value % 10) as i8);
}

fn WriteHexadecimal(value: u32) {
    Write("0x");
    let mut i: u32 = 7;

    loop {
        let nibble = ((value >> (i * 4)) & 0xF) as u8;

        if nibble < 10 {
            WriteCharacter('0' + nibble as i8);
        } else {
            WriteCharacter('A' + (nibble as i8 - 10));
        }

        if i == 0 {
            break;
        } i -= 1;
    }
}

fn SetLEDs(leds: i8) {
    *(0xFFF0 as *mut i8) = leds;
}

fn SetWS2812(_r: u8, _g: u8, _b: u8, brightness: u8) {
    let (mut r, mut g, mut b) = (_r as u32, _g as u32, _b as u32);

    if brightness < 255 {
        r = (r * brightness as u32) / 255;
        g = (g * brightness as u32) / 255;
        b = (b * brightness as u32) / 255;
    }

    *(0xFFE0 as *mut u32) = (g << 16) | (r << 8) | b;
}

fn HasCharacter() -> bool {
    return (*(0xFFFC as *u32) & 1) != 0;
}

fn ReadCharacter() -> i8 {
    return *(0xFFFF as *u32) as i8;
}

fn ButtonPressed() -> bool {
    return (*(0xFFF4 as *u32) & 1) == 0;
}

fn GetTime() -> u32 {
    return *(0xFFEC as *u32);
}

fn Sleep(ms: u32) {
    let start = GetTime();
    while GetTime() - start < ms {}
}

fn SetBaudRate(baud: u32) {
    *(0xFFF8 as *mut u32) = CLK_FREQ / baud;
}

/* class DivisionResult {
    pub quotient: u32,
    pub remainder: u32;
}

fn SoftwareDivide(dividend: u32, divisor: u32) -> DivisionResult {
    let result = DivisionResult();
    result.remainder = dividend;

    while result.remainder >= divisor {
        result.remainder -= divisor;
        result.quotient += 1;
    } return result;
} */

@nomangle
fn Main() {
    SetBaudRate(115200);
    Sleep(1);

    /* let software_start = GetTime();
    let software_result = SoftwareDivide(CLK_FREQ, 115200);
    let software_time = GetTime() - software_start;

    Write("Software division took ");
    WriteInteger(software_start);
    WriteLine(" ms.");

    let hardware_start = GetTime();
    let hardware_result = CLK_FREQ / 115200;
    let hardware_time = GetTime() - hardware_start;

    Write("Hardware division took ");
    WriteInteger(hardware_time);
    WriteLine(" ms."); */

    WriteLine("Zodiac interactive terminal initialized!");
    WriteLine("Type anything to echo, press 1-6 to toggle LEDs, or +/- to change RGB brightness.");
    WriteLine("Press the button on the board to cycle WS2812 animation modes.");

    let mut address: u32 = 0x40000000;
    let mut written_value: u32 = 0xDEADBEEF;
    WriteLine("Running SDRAM test...");
    *(address as *mut u32) = written_value;
    Write("Written ");
    WriteHexadecimal(written_value);
    Write(" to ");
    WriteHexadecimal(address);
    WriteLine(".");
    let mut read_value = *(address as *u32);
    Write("Read ");
    WriteHexadecimal(read_value);
    Write(" from ");
    WriteHexadecimal(address);
    WriteLine(".");

    if read_value == written_value {
        WriteLine("SDRAM test successful!");
    } else {
        WriteLine("SDRAM test failed!");
    }

    address = 0x80000000;
    WriteLine("Running flash read test...");
    read_value = *(address as *u32);
    Write("Read ");
    WriteHexadecimal(read_value);
    Write(" from ");
    WriteHexadecimal(address);
    WriteLine(".");

    if read_value == *(0x00000000 as *u32) {
        WriteLine("Flash read test successful!");
    } else {
        WriteLine("Flash read test failed!");
    }

    let mut color_state = 0;
    let (mut r: u8, mut g: u8, mut b: u8) = (255, 0, 0);
    let mut led_state: i8 = 0x3F;
    SetLEDs(led_state);

    let mut mode = 0;
    let mut key_state = !ButtonPressed();
    let mut next_tick = GetTime() + 10;
    let mut brightness: u8 = 64;

    loop {
        let now = GetTime();

        if ButtonPressed() {
            if key_state {
                mode += 1;
                if mode > 4 { mode = 0; }
                key_state = false;
                Write("WS2812 Mode: ");
                WriteInteger(mode);
                Write("\n");
            }
        } else {
            key_state = true;
        }

        if now >= next_tick {
            next_tick = now + 10;

            if mode == 0 {
                if color_state == 0 {
                    g += 5;

                    if g >= 255 {
                        color_state = 1;
                        g = 255;
                    }
                } else if color_state == 1 {
                    if r <= 5 {
                        color_state = 2;
                        r = 0;
                    } else {
                        r -= 5;
                    }
                } else if color_state == 2 {
                    b += 5;

                    if b >= 255 {
                        color_state = 3;
                        b = 255;
                    }
                } else if color_state == 3 {
                    if g <= 5 {
                        color_state = 4;
                        g = 0;
                    } else {
                        g -= 5;
                    }
                } else if color_state == 4 {
                    r += 5;

                    if r >= 255 {
                        color_state = 5;
                        r = 255;
                    }
                } else {
                    if b <= 5 {
                        color_state = 0;
                        b = 0;
                    } else {
                        b -= 5;
                    }
                }

                SetWS2812(r, g, b, brightness);
            } else if mode == 1 {
                SetWS2812(255, 0, 0, brightness);
            } else if mode == 2 {
                SetWS2812(0, 255, 0, brightness);
            } else if mode == 3 {
                SetWS2812(0, 0, 255, brightness);
            } else {
                SetWS2812(0, 0, 0, brightness);
            }
        }

        if HasCharacter() {
            let c = ReadCharacter();

            if c >= '1' && c <= '6' {
                led_state ^= 1 << (c - '1');
                SetLEDs(led_state);
            } else if c == '+' {
                if brightness >= 247 { brightness = 255; }
                else { brightness += 8; }
                Write("Brightness: ");
                WriteInteger(brightness as u32);
                Write("/255\n");
            } else if c == '-' {
                if brightness <= 8 { brightness = 0; }
                else { brightness -= 8; }
                Write("Brightness: ");
                WriteInteger(brightness as u32);
                Write("/255\n");
            } else {
                WriteCharacter(c);
            }
        }
    }
}
