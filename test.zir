const CLK_FREQ: u32 = 33000000u32;

func WriteCharacter(character: i8) {
    while (*(0xFFFCu32 as *const u32) & 2u32) != 0u32 {}
    *(0xFFFFu32 as *mut i8) = character;
}

func Write(mut string: *const i8) {
    while *string != '\0' {
        WriteCharacter(*string);
        string = string + 1u64;
    }
}

func WriteLine(string: *const i8) {
    Write(string);
    WriteCharacter('\n');
}

func WriteInteger(mut value: i32) {
    if value < 0i32 {
        WriteCharacter('-');
        value = -value;
    }

    if value >= 10i32 {
        WriteInteger(value / 10i32);
    }

    WriteCharacter(48i8 + (value % 10i32) as i8);
}

func WriteInteger(value: u32) {
    if value >= 10u32 {
        WriteInteger(value / 10u32);
    }

    WriteCharacter(48i8 + (value % 10u32) as i8);
}

func WriteHexadecimal(value: u32) {
    Write("0x");
    let mut i = 7i32;

    loop {
        if i < 0i32 { break; }
        let nibble = ((value >> (i as u32 * 4u32)) & 0xFu32) as i8;
        
        if nibble < 10i8 {
            WriteCharacter(48i8 + nibble);
        } else {
            WriteCharacter(55i8 + nibble);
        } i -= 1i32;
    }
}

func SetLEDs(leds: i8) {
    *(0xFFF0u32 as *mut i8) = leds;
}

func SetWS2812(_r: u8, _g: u8, _b: u8, brightness: u8) {
    let (mut r, mut g, mut b) = (_r as u32, _g as u32, _b as u32);

    if brightness < 255u8 {
        r = (r * brightness as u32) / 255u32;
        g = (g * brightness as u32) / 255u32;
        b = (b * brightness as u32) / 255u32;
    }

    *(0xFFE0u32 as *mut u32) = (g << 16u32) | (r << 8u32) | b;
}

func HasCharacter() -> bool {
    ret (*(0xFFFCu32 as *const u32) & 1u32) != 0u32;
}

func ReadCharacter() -> i8 {
    ret *(0xFFFFu32 as *const u32) as i8;
}

func ButtonPressed() -> bool {
    ret (*(0xFFF4u32 as *const u32) & 1u32) == 0u32;
}

func GetTime() -> u32 {
    ret *(0xFFECu32 as *const u32);
}

func Sleep(ms: u32) {
    let start = GetTime();
    while GetTime() - start < ms {}
}

func SetBaudRate(baud: u32) {
    *(0xFFF8u32 as *mut u32) = CLK_FREQ / baud;
}

